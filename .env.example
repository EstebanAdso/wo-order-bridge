# ============================================================================
#  Plantilla de variables de entorno - Plataforma de Cotizaciones y Pedidos
#  Copia este archivo como `.env.local` y rellena los valores reales.
#  NUNCA subas `.env.local` al repositorio (ya está en .gitignore).
#  Todo lo específico de la empresa vive AQUÍ, no en el código.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (base de datos + autenticación + tiempo real)
# Obtén estos valores en: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"
# Clave de servicio: SOLO se usa en el servidor. Da acceso total. Trátala como una contraseña.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"

# ----------------------------------------------------------------------------
# World Office Cloud (integración API REAL - plan Enterprise)
# Durante el concurso se usa el cliente MOCK (WORLDOFFICE_MODE=mock).
# Para producción: WORLDOFFICE_MODE=live + los valores reales de la cuenta.
# El token se copia desde World Office: Configuración > General > API.
# Auth real: header  Authorization: WO <token>  (no es Bearer).
# ----------------------------------------------------------------------------
WORLDOFFICE_MODE="mock"                       # mock | live
WORLDOFFICE_API_BASE_URL="https://api.worldoffice.cloud/api/v1"
WORLDOFFICE_API_TOKEN="token-jwt-de-world-office"
WORLDOFFICE_EMPRESA_ID="EMPRESA-DEMO"         # etiqueta para el payload neutro (modo mock)

# IDs de configuración contable de la cuenta real (confirmar en World Office).
# documentoTipo se confirma con el servicio "listar tipos de documento".
WORLDOFFICE_ID_EMPRESA=""                      # idEmpresa (numérico)
WORLDOFFICE_ID_TERCERO_INTERNO=""             # responsable/vendedor en WO (numérico)
WORLDOFFICE_ID_FORMA_PAGO=""                  # idFormaPago (numérico)
WORLDOFFICE_ID_MONEDA=""                      # idMoneda (numérico, ej. COP)
WORLDOFFICE_ID_BODEGA=""                      # idBodega (numérico)
WORLDOFFICE_DOCTIPO_FACTURA="FV"              # tipo documento factura de venta
WORLDOFFICE_DOCTIPO_PEDIDO="PD"               # tipo documento pedido (confirmar)

# ----------------------------------------------------------------------------
# Gmail API (notificación por correo al área contable)
# Configurado vía cuenta de servicio o OAuth2. Ver docs/INTEGRACION-WORLD-OFFICE.md
# ----------------------------------------------------------------------------
GMAIL_SENDER="notificaciones@tu-empresa.com"
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
NOTIFICACIONES_CONTABLE_TO="contabilidad@tu-empresa.com"

# ----------------------------------------------------------------------------
# Aplicación (identidad/marca: cámbialo por empresa sin tocar el código)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Cotizaciones y Pedidos"
NEXT_PUBLIC_EMPRESA_NOMBRE="Tu Empresa S.A.S"
APP_BASE_URL="http://localhost:3000"
